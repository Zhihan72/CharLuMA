import matplotlib.pyplot as plt

tick_labels = {{ tick_labels }}
group_labels = {{ group_labels }}
q1 = {{ q1 }}
med = {{ med }}
q3 = {{ q3 }}
whislo = {{ whislo }}
whishi = {{ whishi }}
colors = {{ colors }}

n_group = len(tick_labels)
n_subgroup = len(group_labels)
group_width = 0.8
box_width = group_width / n_subgroup
spacing = 1.0

# Compute positions
positions = []
labels = []
box_stats = []

for i in range(n_group):
    for j in range(n_subgroup):
        x_pos = i * spacing + j * box_width
        positions.append(x_pos)
        labels.append(group_labels[j])

        box_stats.append({
            'label': '',  # leave blank to avoid duplicated tick labels
            'q1': q1[j][i],
            'med': med[j][i],
            'q3': q3[j][i],
            'whislo': whislo[j][i],
            'whishi': whishi[j][i],
            'fliers': []
        })

fig, ax = plt.subplots(figsize=({{ width }}, {{ height }}))

# Plot
ax.bxp(box_stats, showfliers=False, patch_artist=True, positions=positions, widths=box_width * 0.9)

for i, patch in enumerate(ax.patches):
    color = colors[i % n_subgroup]
    patch.set_facecolor(color)
    {% if alphas %}patch.set_alpha({{ alphas }}){% endif %}

# Set tick positions and labels at center of each group
group_centers = [(i + 0.5 * (n_subgroup - 1) * box_width) for i in range(n_group)]
ax.set_xticks(group_centers)
ax.set_xticklabels(tick_labels)

{% if x_label %}
ax.set_xlabel("{{ x_label }}", fontsize={{ x_font_size }}, fontweight="{{ x_font_weight }}", fontstyle="{{ x_font_style }}")
{% endif %}
{% if y_label %}
ax.set_ylabel("{{ y_label }}", fontsize={{ y_font_size }}, fontweight="{{ y_font_weight }}", fontstyle="{{ y_font_style }}")
{% endif %}
{% if title %}
ax.set_title("{{ title }}", fontsize={{ title_font_size }}, fontweight="{{ title_font_weight }}", fontstyle="{{ title_font_style }}")
{% endif %}

{% if has_tick %}
ax.set_yticks({{ sec_ticks }})
ax.set_yticklabels({{ sec_tick_labels }})
{% endif %}

{% if has_grid %}
ax.grid(True)
{% endif %}

{% if has_panel_box %}
for spine in ax.spines.values():
    spine.set_visible(True)
{% endif %}

ax.set_facecolor("{{ background_color }}")

{% if has_annot %}
annotations = {{ annotations }}
for i, label in enumerate(annotations):
    ax.text(positions[i], med[i // n_subgroup][i % n_subgroup], label,
            ha="{{ annotation_ha }}", va="{{ annotation_va }}",
            fontweight="{{ annotation_weight }}", fontstyle="{{ annotation_style }}")
{% endif %}

{% if has_legend %}
legend_patches = [
    plt.Rectangle((0, 0), 1, 1, facecolor=colors[j], edgecolor='black')
    for j in range(n_subgroup)
]
ax.legend(legend_patches, group_labels, loc="{{ legend_loc }}", ncol={{ legend_ncols }})
{% endif %}

plt.tight_layout()
plt.show()
