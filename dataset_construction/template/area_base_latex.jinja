\documentclass{standalone}
\usepackage{pgfplots}
\pgfplotsset{compat=1.18}
\usepgfplotslibrary{fillbetween}
\usepackage[x11names, rgb]{xcolor}

{{ color_define }}

\begin{document}
\begin{tikzpicture}
\begin{axis}[
    width={{ width }}in,
    height={{ height }}in,
    {% if title %}
    title={{ title }},
    title style={font={{ title_font_size }}{{ title_font_face }}},
    {% endif %}
    {% if x_label %}
    xlabel={{ x_label }},
    x tick label style={font={{ x_font_size }}{{ x_font_face }}, align=center},
    {% endif %}
    {% if y_label %}
    ylabel={{ y_label }},
    y tick label style={font={{ y_font_size }}{{ y_font_face }}, align=center},
    {% endif %}
    {% if has_x_str %}
    xtick={{ x_pos_str }},
    xticklabels={{ tick_labels }},
    {% endif %}
    {% if has_tick %}
    ytick={{ sec_ticks }},
    yticklabels={{ sec_tick_labels }},
    ymin={{ sec_limit_low }},
    ymax={{ sec_limit_high }},
    {% endif %}
    enlarge x limits=0.05,
    enlarge y limits=0.05,
    {% if has_grid %}
    grid=major,
    {% else %}
    grid=none,
    {% endif %}
    {% if has_panel_box %}
    axis lines=box,
    {% else %}
    axis lines=left,
    {% endif %}
    {% if has_legend %}
    legend style={legend pos={{ legend_loc }}, legend columns={{ legend_ncols }}},
    {% endif %}
    {% if has_annot %}
    nodes near coords,
    {% endif %}
    axis background/.style={fill={{ background_color }}}
]

% Area under the curve
\addplot+[
    draw=none,
    mark=none,
    fill={{ colors }},
    fill opacity={{ alphas }}
] coordinates {
    {% for j in range(x_values | length) %}
    ({{ x_values[j] }}, {{ y_values[j] }})
    {% endfor %}
} \closedcycle;

\end{axis}
\end{tikzpicture}
\end{document}